generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  timezone     String   @default("UTC")
  currency     String   @default("USD")
  avatarUrl    String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts   Account[]
  strategies Strategy[]
  trades     Trade[]
  diary      DiaryEntry[]
}

model Account {
  id             String   @id @default(uuid())
  userId         String
  name           String
  broker         String?
  initialBalance Decimal?
  currentBalance Decimal?
  currency       String?
  type           AccountType
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  trades Trade[]
}

model Trade {
  id          String       @id @default(uuid())
  accountId   String
  userId      String
  strategyId  String?
  symbol      String
  direction   TradeDirection
  status      TradeStatus
  entryDate   DateTime
  exitDate    DateTime?
  entryPrice  Decimal
  exitPrice   Decimal?
  quantity    Decimal
  stopLoss    Decimal?
  takeProfit  Decimal?
  commission  Decimal     @default(0)
  pnl         Decimal?
  pnlPercent  Decimal?
  setup       String?
  notes       String?
  emotion     TradeEmotion?
  rating      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account   Account   @relation(fields: [accountId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  strategy  Strategy? @relation(fields: [strategyId], references: [id])
  tags      TradeTag[]
  screenshots TradeScreenshot[]
  diaryLinks TradeDiaryLink[]
}

model Strategy {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  rules       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  trades Trade[]
}

model TradeTag {
  id      String @id @default(uuid())
  tradeId String
  tagName String

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model TradeScreenshot {
  id      String           @id @default(uuid())
  tradeId String
  fileUrl String
  type    ScreenshotType
  createdAt DateTime @default(now())

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

model DiaryEntry {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime
  content   String?
  moodScore Int?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User             @relation(fields: [userId], references: [id])
  tradeLinks TradeDiaryLink[]
}

model TradeDiaryLink {
  tradeId      String
  diaryEntryId String

  trade      Trade      @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  diaryEntry DiaryEntry @relation(fields: [diaryEntryId], references: [id], onDelete: Cascade)

  @@id([tradeId, diaryEntryId])
}

enum AccountType {
  stocks
  forex
  crypto
  futures
  options
}

enum TradeDirection {
  long
  short
}

enum TradeStatus {
  open
  closed
}

enum TradeEmotion {
  calm
  fearful
  greedy
  confident
}

enum ScreenshotType {
  before
  after
  notes
}

